# ── LINE LIFF ──────────────────────────────────────────────
# LIFF ID จาก LINE Developers Console (Public — ใช้ฝั่ง Client ได้)
NEXT_PUBLIC_LIFF_ID=

# ── Supabase ───────────────────────────────────────────────
# Public keys (ฝั่ง Client)
NEXT_PUBLIC_SUPABASE_URL=
# Publishable key (แบบใหม่ sb_publishable_...) ใช้กับ @supabase/ssr
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service Role Key (ฝั่ง Server เท่านั้น — ห้ามขึ้นต้นด้วย NEXT_PUBLIC)
SUPABASE_SERVICE_ROLE_KEY=

# ── Session ────────────────────────────────────────────────
# Secret สำหรับเซ็น session cookie
SESSION_SECRET=
